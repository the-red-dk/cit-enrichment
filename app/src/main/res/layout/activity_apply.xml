<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/green8bg" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header Layout (Back Button + Title) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnBackApply"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_glass_circle_profile"
                    android:src="@drawable/ic_back_arrow"
                    android:contentDescription="Back"
                    app:tint="@color/cit_text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/apply_title"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="28sp"
                    android:textColor="@color/cit_text_primary" />
            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />

            <!-- Applications List -->
            <!-- NPTEL -->
            <LinearLayout
                android:id="@+id/btnApplyNptel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_item"
                android:paddingHorizontal="20dp"
                android:paddingVertical="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_school" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/apply_nptel"
                    android:textSize="16sp"
                    android:textColor="@color/cit_text_primary" />
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <!-- GATE -->
            <LinearLayout
                android:id="@+id/btnApplyGate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_item"
                android:paddingHorizontal="20dp"
                android:paddingVertical="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_school" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/apply_gate"
                    android:textSize="16sp"
                    android:textColor="@color/cit_text_primary" />
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <!-- Hackathon -->
            <LinearLayout
                android:id="@+id/btnApplyHackathon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_item"
                android:paddingHorizontal="20dp"
                android:paddingVertical="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_laptop" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/apply_hackathon"
                    android:textSize="16sp"
                    android:textColor="@color/cit_text_primary" />
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <!-- Sports -->
            <LinearLayout
                android:id="@+id/btnApplySports"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_item"
                android:paddingHorizontal="20dp"
                android:paddingVertical="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_sports" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/apply_sports"
                    android:textSize="16sp"
                    android:textColor="@color/cit_text_primary" />
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <!-- Patent Filing -->
            <LinearLayout
                android:id="@+id/btnApplyPatent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_item"
                android:paddingHorizontal="20dp"
                android:paddingVertical="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_star" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/apply_patent"
                    android:textSize="16sp"
                    android:textColor="@color/cit_text_primary" />
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <!-- Research Publication -->
            <LinearLayout
                android:id="@+id/btnApplyPublication"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_item"
                android:paddingHorizontal="20dp"
                android:paddingVertical="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_laptop" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/apply_publication"
                    android:textSize="16sp"
                    android:textColor="@color/cit_text_primary" />
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <!-- Conferences -->
            <LinearLayout
                android:id="@+id/btnApplyConferences"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_item"
                android:paddingHorizontal="20dp"
                android:paddingVertical="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_star" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/apply_conferences"
                    android:textSize="16sp"
                    android:textColor="@color/cit_text_primary" />
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
