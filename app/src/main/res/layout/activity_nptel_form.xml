<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/green12bg" />

    <ScrollView
        android:id="@+id/scrollNptelForm"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnBackNptel"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_glass_circle_profile"
                    android:contentDescription="Back"
                    android:src="@drawable/ic_back_arrow"
                    app:tint="@color/cit_text_primary" />

                <TextView
                    android:id="@+id/txtFormTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/nptel_title"
                    android:textColor="@color/cit_text_primary"
                    android:textSize="28sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_auth_card"
                android:orientation="vertical"
                android:padding="24dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutStudentName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundMode="none"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputStudentName"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_glass_input"
                        android:hint="@string/label_student_name"
                        android:imeOptions="actionNext"
                        android:maxLines="1"
                        android:nextFocusDown="@id/inputRegisterNumber"
                        android:paddingHorizontal="24dp"
                        android:textColor="@color/cit_text_primary"
                        android:textColorHint="#E6FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutRegisterNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="none"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputRegisterNumber"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_glass_input"
                        android:hint="@string/label_register_number"
                        android:imeOptions="actionNext"
                        android:maxLines="1"
                        android:nextFocusDown="@id/inputDepartment"
                        android:paddingHorizontal="24dp"
                        android:textColor="@color/cit_text_primary"
                        android:textColorHint="#E6FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutDepartment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="none"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputDepartment"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_glass_input"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:hint="@string/label_department"
                        android:maxLines="1"
                        android:paddingHorizontal="24dp"
                        android:textColor="@color/cit_text_primary"
                        android:textColorHint="#E6FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutYear"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="none"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputYear"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_glass_input"
                        android:hint="@string/label_year"
                        android:imeOptions="actionNext"
                        android:maxLines="1"
                        android:nextFocusDown="@id/inputCourseName"
                        android:paddingHorizontal="24dp"
                        android:textColor="@color/cit_text_primary"
                        android:textColorHint="#E6FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutCourseName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="none"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputCourseName"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_glass_input"
                        android:hint="@string/label_course_name"
                        android:imeOptions="actionNext"
                        android:maxLines="1"
                        android:nextFocusDown="@id/inputCourseId"
                        android:paddingHorizontal="24dp"
                        android:textColor="@color/cit_text_primary"
                        android:textColorHint="#E6FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutCourseId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="none"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputCourseId"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_glass_input"
                        android:hint="@string/label_course_id"
                        android:imeOptions="actionNext"
                        android:maxLines="1"
                        android:nextFocusDown="@id/inputExamDate"
                        android:paddingHorizontal="24dp"
                        android:textColor="@color/cit_text_primary"
                        android:textColorHint="#E6FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutExamDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="none"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputExamDate"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_glass_input"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:hint="@string/label_exam_date"
                        android:maxLines="1"
                        android:nextFocusDown="@id/inputScore"
                        android:paddingHorizontal="24dp"
                        android:textColor="@color/cit_text_primary"
                        android:textColorHint="#E6FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutScore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="none"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputScore"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_glass_input"
                        android:hint="@string/label_score"
                        android:imeOptions="actionNext"
                        android:maxLines="1"
                        android:nextFocusDown="@id/inputAmountPaid"
                        android:paddingHorizontal="24dp"
                        android:textColor="@color/cit_text_primary"
                        android:textColorHint="#E6FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutAmountPaid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundMode="none"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputAmountPaid"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_glass_input"
                        android:hint="@string/label_amount_paid"
                        android:imeOptions="actionNext"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:nextFocusDown="@id/inputRemarks"
                        android:paddingHorizontal="24dp"
                        android:textColor="@color/cit_text_primary"
                        android:textColorHint="#E6FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/label_certificate"
                    android:textColor="#E6FFFFFF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickCertificate"
                    style="@style/Widget.CIT.PillButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/action_pick_certificate"
                    android:textColor="@color/cit_text_primary"
                    app:backgroundTint="#33FFFFFF"
                    app:cornerRadius="12dp"
                    app:strokeColor="#80FFFFFF"
                    app:strokeWidth="1.5dp" />

                <TextView
                    android:id="@+id/txtCertificateName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/label_no_file"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/label_payment_proof"
                    android:textColor="#E6FFFFFF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickPayment"
                    style="@style/Widget.CIT.PillButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/action_pick_payment"
                    android:textColor="@color/cit_text_primary"
                    app:backgroundTint="#33FFFFFF"
                    app:cornerRadius="12dp"
                    app:strokeColor="#80FFFFFF"
                    app:strokeWidth="1.5dp" />

                <TextView
                    android:id="@+id/txtPaymentName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/label_no_file"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:boxBackgroundMode="none"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputRemarks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_glass_input"
                        android:gravity="top|start"
                        android:hint="@string/label_remarks"
                        android:imeOptions="actionDone"
                        android:inputType="textMultiLine"
                        android:minHeight="100dp"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="16dp"
                        android:textColor="@color/cit_text_primary"
                        android:textColorHint="#E6FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitNptel"
                    style="@style/Widget.CIT.PillButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:text="@string/action_submit"
                    android:textColor="#1B2129"
                    app:backgroundTint="@color/cit_primary"
                    app:cornerRadius="12dp" />

                <ProgressBar
                    android:id="@+id/progressNptel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/txtUploadStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:textColor="@color/cit_text_primary"
                    android:textSize="13sp"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
