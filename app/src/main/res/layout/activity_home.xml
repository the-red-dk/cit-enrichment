<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/green2bg" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_card"
                android:padding="4dp"
                android:src="@drawable/ic_launcher_round" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/home_title"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="@color/cit_text_primary" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_dialog_info"
                android:tint="@color/cit_card_glow" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtHomeSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/home_subtitle"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="@color/cit_text_muted" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/cit_surface"
            app:cardElevation="6dp"
            app:strokeColor="@color/cit_card_glow"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_card_title"
                    android:textColor="@color/cit_text_muted" />

                <TextView
                    android:id="@+id/txtHomeCardAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="0.00"
                    android:textAppearance="?attr/textAppearanceHeadlineMedium"
                    android:textColor="@color/cit_text_primary" />

                <TextView
                    android:id="@+id/txtHomeCardHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/home_card_hint"
                    android:textColor="@color/cit_text_muted" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApply"
                style="@style/Widget.CIT.HomeGlassButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/action_apply"
                android:textColor="@color/cit_text_primary"
                android:textSize="12sp"
                app:backgroundTint="@color/home_button_tint" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTrack3"
                style="@style/Widget.CIT.HomeGlassButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/action_track"
                android:textColor="@color/cit_text_primary"
                app:backgroundTint="@color/home_button_tint" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPolicyInfo"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:text="@string/action_policy_info"
                android:textColor="@color/cit_text_primary"
                style="@style/Widget.CIT.HomeGlassButton"
                app:backgroundTint="@color/home_button_tint" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNotifications"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:text="@string/action_notifications"
                android:textColor="@color/cit_text_primary"
                style="@style/Widget.CIT.HomeGlassButton"
                app:backgroundTint="@color/home_button_tint" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="88dp" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnProfile"
        style="@style/Widget.CIT.HomeGlassButton"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="20dp"
        android:text="@string/action_profile"
        android:gravity="center"
        android:textColor="@color/cit_on_primary"
        app:backgroundTint="@color/cit_primary"
        app:cornerRadius="12dp"
        app:icon="@android:drawable/ic_menu_myplaces"
        app:iconGravity="textStart"
        app:iconPadding="10dp"
        app:iconSize="18dp"
        app:iconTint="@color/cit_on_primary"
        app:strokeColor="@color/cit_primary_variant"
        app:strokeWidth="1dp" />
</FrameLayout>
