<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_glass_item_profile"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="14dp">

    <TextView
        android:id="@+id/txtDeviceTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This device"
        android:textColor="@color/cit_text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:id="@+id/txtDeviceSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Last seen"
        android:textColor="@color/cit_text_muted"
        android:textSize="12sp" />

</LinearLayout>
