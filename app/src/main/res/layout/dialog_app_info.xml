<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_item_profile"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/txtAppInfoTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_info_title"
        android:textColor="@color/cit_text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtAppInfoBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingExtra="2dp"
        android:text="@string/app_info_description"
        android:textColor="@color/cit_text_primary"
        android:textSize="14sp" />
</LinearLayout>
